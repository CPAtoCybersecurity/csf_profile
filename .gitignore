# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
server/node_modules/
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.env
.env.*
server/.env
server/.env.*
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Server config with credentials (use config.example.json as template)
server/config.json

# Internal reports and confidential documents
_reports/
_internal/

# Safety-net globs: any file marked .internal or .scratch is ignored wherever it lives
*.internal.md
*.scratch.md
SCRATCH-*.md

# VS Code workspace file — personal setup, not shared
*.code-workspace

# Backup files
*.backup

# Pre-restore auto-backups contain a full copy of assessment data — never repo content
*.backup.json
backups/

# Private data packs hold an org's real assessment data — never repo content.
# (The committed test fixture is named *.packfixture.json on purpose: it is
# fictional and must not match this pattern.)
*.csfpack.json
private-data/

# Metrics catalogues are the user's own (possibly licensed) content — never
# repo content. (The committed test fixture is named *.metricsfixture.csv on
# purpose: it is fictional and must not match this pattern.)
*.csfmetrics.csv

# Server-local persisted state (entry-id mappings) — deployment data, not code
server/data/

# ScubaGoggles/ScubaGear output describes a real tenant's security posture —
# never repo content. Covers the default output names and renamed copies.
ScubaResults*.json
*.scubaresults.json

CLAUDE.md
