# JIRA Configuration
# Your JIRA instance URL (e.g., https://your-domain.atlassian.net)
REACT_APP_JIRA_INSTANCE_URL=

# JIRA API Token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
REACT_APP_JIRA_API_TOKEN=

# Confluence Configuration
# Your Confluence instance URL (e.g., https://your-domain.atlassian.net/wiki)
REACT_APP_CONFLUENCE_INSTANCE_URL=

# Confluence API Token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
REACT_APP_CONFLUENCE_API_TOKEN=

# Backend server url
REACT_APP_API_URL='http://localhost:4000'

# Claude AI (backend-only — never exposed to the browser)
# Anthropic API key used by the backend proxy at /api/ai/claude
CLAUDE_API_KEY=
# Optional model override (defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=

# Note: Never commit the actual .env file to version control
# Copy this file to .env and fill in your actual values
